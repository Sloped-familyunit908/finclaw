# AI Trading Engine Config
# Copy this to .env and fill in your keys

# AI Model (Claude API - or leave empty to use local)
ANTHROPIC_API_KEY=

# Exchange APIs (optional - only for live trading)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# OKX (optional)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Alpaca (optional - for US stocks)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Trading Settings
TRADING_MODE=paper
INITIAL_CAPITAL=10000
DEFAULT_ASSETS=BTC,ETH,SOL
MAX_POSITION_SIZE_PCT=0.2
STOP_LOSS_PCT=0.05

# Dashboard
DASHBOARD_PORT=8080
