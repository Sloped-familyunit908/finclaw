# AutoTrading Configuration
# Copy this file to autotrading.env and fill in your LLM settings.
#
# The runner script (run.py) reads this file to connect to your LLM.
# Never commit your real API keys — autotrading.env is in .gitignore.

# LLM Provider — any OpenAI-compatible API works
# Examples: openai, anthropic, deepseek, groq, ollama, agent-maestro
LLM_PROVIDER=openai

# API endpoint
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
# Groq:      https://api.groq.com/openai/v1
# Ollama:    http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name
LLM_MODEL=gpt-4.1-mini

# API key (set this in your real autotrading.env, not here)
LLM_API_KEY=

# Max stocks to load for backtesting (fewer = faster iteration)
MAX_STOCKS=200

# Backtest timeout in seconds
BACKTEST_TIMEOUT=300
